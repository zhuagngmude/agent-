{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agent-swarm",
  "version": "0.1.0",
  "identifier": "com.agent-swarm.desktop",
  "build": {
    "frontendDist": "../../../packages/ui/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "cd ../../packages/ui && npm run dev -- --host 127.0.0.1 --port 5173 --strictPort",
    "beforeBuildCommand": "cd ../../packages/ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "agent蜂群",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
